{
  "name": "@nuzo/mcp-server",
  "version": "0.1.3",
  "private": true,
  "description": "MCP server for Nuzo.",
  "keywords": [
    "ai-agents",
    "mcp",
    "memory",
    "codex",
    "claude-code",
    "local-first"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "bin": {
    "nuzo-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build -w @nuzo/memory-core && tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @nuzo/memory-core && npm run build && vitest run src"
  },
  "dependencies": {
    "@nuzo/memory-core": "0.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
