{
  "mcpServers": {
    "nuzo": {
      "command": "npm",
      "args": [
        "exec",
        "--yes",
        "--package=@nuzo/memory@0.9.1",
        "--",
        "nuzo-mcp-server"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "NUZO_PROJECT_ROOT": "${CLAUDE_PROJECT_DIR}"
      }
    }
  }
}
