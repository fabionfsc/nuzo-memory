{
  "description": "Recall relevant Nuzo memory at session start and before each user prompt.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "npm exec --yes --package=@nuzo/memory@0.9.0 -- nuzo-memory-hook",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm exec --yes --package=@nuzo/memory@0.9.0 -- nuzo-memory-hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
